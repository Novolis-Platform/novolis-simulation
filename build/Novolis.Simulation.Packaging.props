<Project>
  <PropertyGroup Label="Novolis.Simulation NuGet metadata">
    <Authors>Novolis</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/Novolis-Platform/novolis-simulation</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Novolis-Platform/novolis-simulation</RepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PackageTags>simulation;world;camera;occupancy;kinematics;racing</PackageTags>
  </PropertyGroup>
</Project>
