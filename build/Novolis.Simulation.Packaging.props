<Project>
  <PropertyGroup Label="Novolis.Simulation NuGet metadata">
    <NovolisSimulationVersion Condition="'$(NovolisSimulationVersion)' == ''">0.0.1.1</NovolisSimulationVersion>
    <Version Condition="'$(NovolisVersionBuild)' == ''">$(NovolisSimulationVersion)</Version>
    <PackageTags>simulation;world;camera;occupancy;kinematics</PackageTags>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
</Project>
