<Project>
  <PropertyGroup Label="Novolis.Simulation NuGet metadata">
    <NovolisSimulationVersion Condition="'$(NovolisSimulationVersion)' == ''">0.4.0-local</NovolisSimulationVersion>
    <Version>$(NovolisSimulationVersion)</Version>
    <PackageTags>simulation;world;camera;occupancy;kinematics</PackageTags>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
</Project>
